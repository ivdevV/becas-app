# Modo de integracion. En dev valida y simula el envio. En prod llama a Odoo.
ODOO_MODE=dev

# Webhook HTTP del modulo irg_student_scholarship_webhook en Odoo 16.
ODOO_SCHOLARSHIP_WEBHOOK_URL=https://tu-odoo.com/irg/scholarship/webhook/document

# Token configurado en Odoo como irg_student_scholarship_webhook.token.
ODOO_SCHOLARSHIP_WEBHOOK_TOKEN="becas_2026_un_token_largo_y_secreto"

# Valores informativos alineados con la validacion del modulo Odoo.
SCHOLARSHIP_MAX_FILE_SIZE_MB=10
SCHOLARSHIP_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.doc,.docx

# Notificacion interna por correo cuando una solicitud se recibe correctamente.
# AWS SES SMTP: cambia la region si tu cuenta usa otra.
# Usa "SMTP Username" y "SMTP Password" de SES, no AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY.
MAIL_HOST=email-smtp.eu-west-1.amazonaws.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=TU_SMTP_USERNAME_DE_AWS_SES
MAIL_PASSWORD="tu-password-smtp-de-aws-ses"
MAIL_FROM="Becas IRG <no-reply@institutoraimongaja.com>"
SCHOLARSHIP_NOTIFICATION_TO=becas.irg@institutoraimongaja.com

# Registro en Google Sheets cuando Odoo acepta la solicitud en prod.
# Comparte la hoja con GOOGLE_SERVICE_ACCOUNT_EMAIL como editor.
GOOGLE_SHEETS_SPREADSHEET_ID=1L6Y8R_a2Tr4nSELipD5VSHd4c2rDL2uBkRgTbNJEoYA
GOOGLE_SHEETS_SHEET_NAME="Hoja 1"
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
